{
  "rewrites": [
    {
      "source": "/spotify-callback",
      "destination": "/vercel-spotify-callback/spotify-callback/index.html"
    },
    {
      "source": "/spotify-callback/",
      "destination": "/vercel-spotify-callback/spotify-callback/index.html"
    }
  ],
  "headers": [
    {
      "source": "/spotify-callback/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
